prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@

Name: @SLIM_LIB@
Description: @SLIM_LIB_DESCRIPTION@
Version: @PROJECT_VERSION@
Cflags: -I${includedir} -std=c++@SLIMLIB_CXX_STANDARD@
Libs: -L${libdir} -l@SLIM_LIB_LOWER@ -Wl,-rpath,${libdir}